# Dependencies (only on Mac dev box, not needed by Xcode)
node_modules/

# NOTE: www/index.html and www/capacitor.js ARE committed
# — they are auto-regenerated by .github/workflows/ios-sync.yml
# whenever well-testing-app.html changes. This means you can clone
# on a Mac and open Xcode directly with no Node install needed.

# Xcode user-specific state (not portable between machines)
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/App/public/

# Capacitor 8+ uses Swift Package Manager (no Podfile/Pods).
# If you downgrade to Cap 7 for any reason, uncomment:
# ios/App/Pods/

# Swift Package Manager — Xcode resolves these from the committed Package.swift
ios/App/App.xcworkspace/xcshareddata/swiftpm/

# Build output
build/
DerivedData/
*.ipa
*.xcarchive

# macOS
.DS_Store

# Xcode
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate
*.xccheckout
*.moved-aside
xcuserdata/
