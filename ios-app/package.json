{
  "name": "h2oil-well-testing-ios",
  "version": "1.1.0",
  "description": "H2Oil Well Testing Suite — native iOS wrapper (Capacitor 7)",
  "private": true,
  "scripts": {
    "sync-main": "node scripts/sync-from-main.js",
    "cap-init": "npx cap add ios",
    "assets": "python3 scripts/make-assets.py && npx @capacitor/assets generate --ios",
    "build": "npm run sync-main && npx cap sync ios",
    "open": "npx cap open ios",
    "ios": "npm run build && npm run open",
    "setup": "npm install && npm run sync-main && npx cap add ios && npx cap sync ios && npx cap open ios",
    "migrate": "npx cap migrate",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@revenuecat/purchases-capacitor": "^10.3.3",
    "@revenuecat/purchases-capacitor-ui": "^10.3.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/assets": "^4.0.0"
  }
}
