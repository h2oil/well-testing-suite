{
  "name": "h2oil-well-testing-ios",
  "version": "1.2.0",
  "description": "H2Oil Well Testing Suite — native iOS wrapper (Capacitor 8)",
  "private": true,
  "scripts": {
    "sync-main": "node scripts/sync-from-main.js",
    "cap-init": "npx cap add ios",
    "assets": "python3 scripts/make-assets.py && npx @capacitor/assets generate --ios",
    "build": "npm run sync-main && npx cap sync ios",
    "open": "npx cap open ios",
    "ios": "npm run build && npm run open",
    "setup": "npm install && npm run sync-main && npx cap add ios && npx cap sync ios && npx cap open ios",
    "migrate": "npx cap migrate",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@revenuecat/purchases-capacitor": "^13.0.1",
    "@revenuecat/purchases-capacitor-ui": "^13.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@capacitor/assets": "^3.0.5"
  }
}
